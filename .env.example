# ---------------------------------------------------------------
# PatientsExcelReport Django API – environment configuration
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------

# Django core
SECRET_KEY=django-insecure-replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# Temp folder for Excel processing  (mirrors C:\PatientSignatureFiles)
PATIENT_SIGNATURE_TEMP_DIR=/tmp/patient_signature_files

# Excel processing  (mirrors appsettings.json ExcelProcessingSettings)
MAX_DEGREE_OF_PARALLELISM=4
SIMILARITY_THRESHOLD=0.75

# ---------------------------------------------------------------
# Database (for API execution logging via SP_WriteApiExecutionLog)
# Leave as SQLite default for development.
# ---------------------------------------------------------------
# MSSQL_SERVER=DEVILSBOSS
# MSSQL_PORT=1433
# MSSQL_DATABASE=PatientsExcelReportLogs
# MSSQL_USER=Kartik
# MSSQL_PASSWORD='Kartik5#'
# MSSQL_TRUSTED_CONNECTION=False